```gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyd
*.pyo
*.exe
*.dll
*.so

# IDE-specific files
.vscode/
.idea/

# Jupyter Notebook / IPython files
.ipynb_checkpoints/

# Python environment
virtualenv/
venv/
env/
.env

# Data files
*.csv
*.xlsx
*.hdf5

# Colab-specific files
# Files generated by Google Colab, often temporary or sensitive
/content/drive/
/content/sample_data/
*.ipynb_metadata

# Checkpoints or saved models
*.pt
*.pth
*.h5

# Log files
*.log

# Temporary files
*~
*.bak
*.swp

